        "type": "object"
      }
    },
    "dictamen_global": {
      "type": "string"
    },
    "critical_parameters": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "artifacts": {
      "type": "object"
    }
  }
}
